Exercise 1:
Query 1: Find the title of each film 
         SELECT Title FROM movies;

Query 2: Find the director of each film 
         SELECT Director FROM movies;

Query 3: Find the title and director of each film 
         SELECT Title, Director FROM movies;

Query 4: Find the title and year of each film
         SELECT Title, Director FROM movies;

Query 6: Find all the information about each film
         SELECT * FROM movies;


Exercise 2:
Query 1: Find the movie with a row id of 6 
         SELECT * FROM movies where id=6;

Query 2: Find the movies released in the years between 2000 and 2010
         SELECT * FROM movies where year Between 2000 and 2010;

Query 3: Find the movies not released in the years between 2000 and 2010
         SELECT * FROM movies where year Not Between 2000 and 2010;

Query 4: Find the first 5 Pixar movies and their release year
         SELECT title, year FROM movies
         WHERE year <= 2003;


Exercise 3:
Query 1: Find all the Toy Story movies
        SELECT title, director FROM movies 
        WHERE title LIKE "Toy Story%";

Query 2: Find all the movies (and director) not directed by John Lasseter
        SELECT title, director FROM movies 
        WHERE director = "John Lasseter";

Query 3: Find all the movies (and director) not directed by John Lasseter
         SELECT title, director FROM movies 
         WHERE director != "John Lasseter";

Query 4: Find all the WALL-* movies
         SELECT * FROM movies 
         WHERE title LIKE "WALL-_";


Exercise 4:
Query 1: List all directors of Pixar movies (alphabetically), without duplicates
         SELECT DISTINCT director FROM movies
         ORDER BY director ASC;

Query 2: List the last four Pixar movies released (ordered from most recent to least)
        SELECT title, year FROM movies
        ORDER BY year DESC
        LIMIT 4;

Query 3: List the first five Pixar movies sorted alphabetically
         SELECT title FROM movies
        ORDER BY title ASC
        LIMIT 5;

Query 4: List the next five Pixar movies sorted alphabetically 
        Select title from movies
        ORDER BY title ASC
        LIMIT 5;


Exercise 5:
Query 1: List all the Canadian cities and their populations
         SELECT city, population FROM north_american_cities
         WHERE country = "Canada";

Query 2: Order all the cities in the United States by their latitude from north to south
         SELECT city, latitude FROM north_american_cities
         WHERE country = "United States"
         ORDER BY latitude DESC;

Query 3: List all the cities west of Chicago, ordered from west to east
         SELECT city, longitude FROM north_american_cities
         WHERE longitude < -87.629798
         ORDER BY longitude ASC;

Query 4: List the two largest cities in Mexico (by population)
         SELECT city, population FROM north_american_cities
         WHERE country LIKE "Mexico"
         ORDER BY population DESC
         LIMIT 2;

Query 5: List the third and fourth largest cities (by population) in the United States and their population
         SELECT city, population FROM north_american_cities
         WHERE country LIKE "United States"
         ORDER BY population DESC
         LIMIT 2 OFFSET 2;


Exercise 6:
Query 1: Find the domestic and international sales for each movie
         SELECT title, domestic_sales, international_sales 
         FROM movies
          JOIN boxoffice
           ON movies.id = boxoffice.movie_id;

Query 2: Show the sales numbers for each movie that did better internationally rather than domestically
         SELECT title, domestic_sales, international_sales
         FROM movies
          JOIN boxoffice
            ON movies.id = boxoffice.movie_id
         WHERE international_sales > domestic_sales;

Query 3: List all the movies by their ratings in descending order
         SELECT title, rating
         FROM movies
           JOIN boxoffice
             ON movies.id = boxoffice.movie_id
         ORDER BY rating DESC;


Exercise 7:
Query 1: Find the list of all buildings that have employees
         SELECT DISTINCT building FROM employees;

Query 2: Find the list of all buildings and their capacity
         SELECT * FROM buildings;

Query 3: List all buildings and the distinct employee roles in each building (including empty buildings)
         SELECT DISTINCT building_name, role 
         FROM buildings 
           LEFT JOIN employees
             ON building_name = building;


Exercise 8: 
Query 1: Find the name and role of all employees who have not been assigned to a building
         SELECT name, role FROM employees
         WHERE building IS NULL;

Query 2: Find the names of the buildings that hold no employees
         SELECT DISTINCT building_name
         FROM buildings 
          LEFT JOIN employees
            ON building_name = building
         WHERE role IS NULL;


Exercise 9:
Query 1: List all movies and their combined sales in millions of dollars 
         SELECT title, (domestic_sales + international_sales) / 1000000 AS gross_sales_millions
         FROM movies
           JOIN boxoffice
            ON movies.id = boxoffice.movie_id;

Query 2: List all movies and their ratings in percent
         SELECT title, rating * 10 AS rating_percent
         FROM movies
          JOIN boxoffice
           ON movies.id = boxoffice.movie_id;

Query 3: List all movies that were released on even number years
         SELECT title, year
         FROM movies
         WHERE year % 2 = 0;


Exercise 10:
Query 1: Find the longest time that an employee has been at the studio
         SELECT MAX(years_employed) as Max_years_employed
         FROM employees;

Query 2: For each role,find the average number of years employed by employees in that role
         SELECT role, AVG(years_employed) as Average_years_employed
         FROM employees
         GROUP BY role;

Query 3: Find the total number of employee years worked in each building
         SELECT building, SUM(years_employed) as Total_years_employed
         FROM employees
         GROUP BY building;


Exercise 11:
Query 1: Find the number of Artists in the studio (without a HAVING clause)
         SELECT role, COUNT(*) as Number_of_artists
         FROM employees
         WHERE role = "Artist";

Query 2: Find the number of Employees of each role in the studio
         SELECT role, COUNT(*)
         FROM employees
         GROUP BY role;

Query 3: Find the total number of years employed by all Engineers
          SELECT role, SUM(years_employed)
          FROM employees
          GROUP BY role
          HAVING role = "Engineer";


